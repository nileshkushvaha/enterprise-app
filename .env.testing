APP_NAME="Sphere Education"
APP_ENV=testing
APP_KEY=base64:wRFXIT3RvX0bIyPlZDmrWgdvDFmhC9bXS3mLqGdJEwc=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# ── Database: dedicated MySQL test database ───────────────────────────────────
# NEVER change this to enterprise_app. Tests use RefreshDatabase which runs
# migrate:fresh — that wipes all tables. enterprise_app_testing is disposable;
# enterprise_app is not.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=enterprise_app_testing
DB_USERNAME=root
DB_PASSWORD=Admin@123

# ── Drivers: all in-memory / null to prevent side-effects ────────────────────
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

# ── Disable monitoring packages in tests ─────────────────────────────────────
ACTIVITYLOG_ENABLED=true
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
BCRYPT_ROUNDS=4
